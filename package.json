{
  "name": "demo_cypress_project",
  "version": "1.0.0",
  "description": "Cypress TypeScript Demo Framework",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:chrome": "cypress run --browser chrome",
    "cy:firefox": "cypress run --browser firefox",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "cy:report": "npm run cy:chrome && npm run allure:generate"
  },
  "keywords": [
    "cypress",
    "typescript",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "@types/node": "^25.9.1",
    "allure-commandline": "^2.42.0",
    "cypress": "^15.16.0",
    "dotenv": "^17.4.2",
    "typescript": "^6.0.3"
  }
}
